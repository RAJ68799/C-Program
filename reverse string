#include <stdio.h>

int main()
{
    char str[100],letter;
    int itr=0,count=0;
    printf("enter the letter after string  ");
    scanf("%c\n",&letter);
    scanf("%[^\n]",str);
    while(str[itr]!='\0')
    {
        
        if(str[itr]==letter)
            count++;
        itr++;
    }
    printf("%d",count);

    return 0;
}
