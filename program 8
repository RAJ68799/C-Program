#include <stdio.h>

void swap(int num1, int num2)
{
    printf("Before Swap: num1 = %d, num2 = %d\n", num1, num2);

    num1 = num1 ^ num2;
    num2 = num1 ^ num2;
    num1 = num1 ^ num2;

    printf("After Swap : num1 = %d, num2 = %d\n", num1, num2);
}

int main()
{
    int a, b;
    scanf("%d %d", &a, &b);

    swap(a, b);

    return 0;
}
