#include <stdio.h>

int main()
{
    int num,count=1;
    scanf("%d",&num);
    for(int itr1=1; count<=num; itr1++)
    {
        for(int itr2=1; itr2<=itr1 && count<=num; itr2++)
        {
            printf("*");
            count+=1;
            
        }
        printf("\n");
    }

    return 0;
}
