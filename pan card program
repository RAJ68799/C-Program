#include <stdio.h>

int main()
{
    int num;
    int i, j,digit=0,frq[10]={0};

    printf("Enter a 10-digit number: ");
    scanf("%d", &num);
    // Check for duplicate digits
    while(num>0)
    {
        digit=num%10;
        if(frq[digit]!= 0)
            break;
        
        
        frq[digit]++;
        
        
        num=num/10;
    }
    if(num==0)
        printf("YES");
    else
        printf("NO");

    return 0;
}
