#include <stdio.h>

int main()
{
    int inp,space,star,line=1;
    scanf("%d",&inp);
    space=inp-line;
   
    {
    for(line=1;line<=inp;line++)
    {
        for(space=1;space<=inp-line;space++)
        {
             printf(" ");
        }
            for(star=1;star<line*2;star++)
            {
                printf("*");
                
            }
        for(space=1;space<=(inp-line)*2;space++)
        {
             printf(" ");
        }
            for(star=1;star<line*2;star++)
            {
                printf("*");
                
            }
        printf("\n");    
    }
    }
   
   
   {
    for(line=inp;line>=1;line--)
    {
        for(space=inp-line;space>=1;space--)
        {
             printf(" ");
        }
            for(star=line*2;star>1;star--)
            {
                printf("*");
                
            }
        for(space=(inp-line)*2;space>=1;space--)
        {
             printf(" ");
        }
            for(star=line*2;star>1;star--)
            {
                printf("*");
                
            }
        printf("\n");    
    }
    }
   
    return 0;
}
